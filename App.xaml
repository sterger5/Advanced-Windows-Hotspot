<Application x:Class="AdvancedWindowsHotspot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Material 3 Color Palette -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#6750A4"/>
        <SolidColorBrush x:Key="OnPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#EADDFF"/>
        <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="#21005D"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#625B71"/>
        <SolidColorBrush x:Key="OnSecondaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#E8DEF8"/>
        <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#1D192B"/>
        <SolidColorBrush x:Key="TertiaryBrush" Color="#7D5260"/>
        <SolidColorBrush x:Key="TertiaryContainerBrush" Color="#FFD8E4"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FEF7FF"/>
        <SolidColorBrush x:Key="SurfaceDimBrush" Color="#DED8E1"/>
        <SolidColorBrush x:Key="SurfaceContainerBrush" Color="#F3EDF7"/>
        <SolidColorBrush x:Key="SurfaceContainerHighBrush" Color="#ECE6F0"/>
        <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#F7F2FA"/>
        <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#E7E0EC"/>
        <SolidColorBrush x:Key="OnSurfaceBrush" Color="#1D1B20"/>
        <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#49454F"/>
        <SolidColorBrush x:Key="OutlineBrush" Color="#79747E"/>
        <SolidColorBrush x:Key="OutlineVariantBrush" Color="#CAC4D0"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#B3261E"/>
        <SolidColorBrush x:Key="OnErrorBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ErrorContainerBrush" Color="#F9DEDC"/>
        <SolidColorBrush x:Key="OnErrorContainerBrush" Color="#410E0B"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#386A20"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F57C00"/>

        <!-- Material 3 Filled Button -->
        <Style x:Key="MaterialFilledButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource OnPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="stateLayer" CornerRadius="24" Background="Transparent"/>
                            <Border x:Name="buttonBorder" CornerRadius="24" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="stateLayer" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="stateLayer" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="buttonBorder" Property="Background" Value="#1D1D1D1F"/>
                                <Setter Property="Foreground" Value="#611D1D1D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Material 3 Tonal Button -->
        <Style x:Key="MaterialTonalButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryContainerBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource OnSecondaryContainerBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="stateLayer" CornerRadius="24" Background="Transparent"/>
                            <Border x:Name="buttonBorder" CornerRadius="24" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="stateLayer" Property="Background" Value="#1A1D192B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="stateLayer" Property="Background" Value="#331D192B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="buttonBorder" Property="Background" Value="#1D1D1D1F"/>
                                <Setter Property="Foreground" Value="#611D1D1D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Material 3 Error Filled Button -->
        <Style x:Key="MaterialErrorButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource OnErrorBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="stateLayer" CornerRadius="24" Background="Transparent"/>
                            <Border x:Name="buttonBorder" CornerRadius="24" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="stateLayer" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="stateLayer" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Material 3 Outlined TextBox -->
        <Style x:Key="MaterialOutlinedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="textFieldBorder" CornerRadius="12" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <TextBlock x:Name="placeholderText" Text="{TemplateBinding Tag}"
                                           Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.6"
                                           VerticalAlignment="Center" Margin="16,0"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="16,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 未聚焦且文本为空时显示占位符 -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="placeholderText" Property="Opacity" Value="0.6"/>
                                <Setter TargetName="placeholderText" Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
                            </MultiTrigger>
                            <!-- 聚焦且文本为空时显示占位符（高亮样式） -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsFocused" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="placeholderText" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="placeholderText" Property="Opacity" Value="1"/>
                                <Setter TargetName="placeholderText" Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="textFieldBorder" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="textFieldBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </MultiTrigger>
                            <!-- 聚焦且有文本时只高亮边框 -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsFocused" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="textFieldBorder" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="textFieldBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </MultiTrigger>
                            <!-- 鼠标悬停时加粗边框 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="textFieldBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Material 3 PasswordBox -->
        <Style x:Key="MaterialOutlinedPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="textFieldBorder" CornerRadius="12" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="16,0" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="textFieldBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="textFieldBorder" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="textFieldBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Material 3 ComboBox -->
        <Style x:Key="MaterialComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceContainerBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="comboBoxBorder" CornerRadius="12" Background="{TemplateBinding Background}">
                                <Grid>
                                    <ToggleButton x:Name="PART_ToggleButton"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Grid Background="Transparent">
                                                    <Path x:Name="arrow" Data="M7,10 L12,15 L17,10" Stroke="{StaticResource OnSurfaceVariantBrush}" StrokeThickness="2"
                                                          HorizontalAlignment="Right" Margin="0,0,16,0" Stretch="Uniform" Width="12"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="PART_ContentSite" Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="16,0,40,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   PopupAnimation="Slide" MinWidth="{TemplateBinding ActualWidth}"
                                   AllowsTransparency="True">
                                <Border x:Name="popupBorder" CornerRadius="12" Background="{StaticResource SurfaceBrush}"
                                        Margin="0,4,0,0" Padding="8" SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Direction="270"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="200" CanContentScroll="False"
                                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="comboBoxBorder" Property="Background" Value="{StaticResource SurfaceContainerHighBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="comboBoxBorder" Property="Background" Value="{StaticResource SurfaceContainerHighBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Material 3 ComboBoxItem -->
        <Style x:Key="MaterialComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Grid>
                            <Border x:Name="stateLayer" CornerRadius="8" Background="Transparent" Margin="0,2">
                                <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="stateLayer" Property="Background" Value="#1A1D1B20"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="stateLayer" Property="Background" Value="{StaticResource SecondaryContainerBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource OnSecondaryContainerBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Material 3 Switch -->
        <Style x:Key="MaterialSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid x:Name="switchContainer" Width="52" Height="32" Margin="-10,0,0,0">
                                <Border x:Name="stateLayer" CornerRadius="16" Background="Transparent"/>
                                <Border x:Name="trackBorder" CornerRadius="16"
                                        Background="{StaticResource SurfaceVariantBrush}"
                                        BorderBrush="{StaticResource OutlineBrush}" BorderThickness="2"
                                        Width="52" Height="32">
                                    <Grid>
                                        <Ellipse x:Name="thumb" Width="16" Height="16"
                                                 Fill="{StaticResource OutlineBrush}"
                                                 HorizontalAlignment="Left" VerticalAlignment="Center"
                                                 Margin="4,0,0,0"/>
                                    </Grid>
                                </Border>
                            </Grid>
                            <ContentPresenter Grid.Column="1" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="stateLayer" Property="Background" Value="#1A1D1B20"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="trackBorder" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="trackBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="thumb" Property="Fill" Value="{StaticResource OnPrimaryBrush}"/>
                                <Setter TargetName="thumb" Property="Width" Value="24"/>
                                <Setter TargetName="thumb" Property="Height" Value="24"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,4,0"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Material 3 Icon Button -->
        <Style x:Key="MaterialIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="stateLayer" CornerRadius="20" Background="Transparent"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="stateLayer" Property="Background" Value="#1A1D1B20"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="stateLayer" Property="Background" Value="#331D1B20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- NullToVisibilityConverter -->
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" xmlns:local="clr-namespace:AdvancedWindowsHotspot.Converters"/>

    </Application.Resources>
</Application>
