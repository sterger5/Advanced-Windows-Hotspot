<Window x:Class="AdvancedWindowsHotspot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AdvancedWindowsHotspot.ViewModels"
        xmlns:converters="clr-namespace:AdvancedWindowsHotspot.Converters"
        xmlns:models="clr-namespace:AdvancedWindowsHotspot.Models"
        Title="Advanced Windows Hotspot"
        Icon="pack://application:,,,/app.ico"
        ResizeMode="CanResizeWithGrip"
        Width="560" Height="700"
        MinWidth="480" MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="14"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="Window_SourceInitialized">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:HotspotStatusToBrushConverter x:Key="StatusToBrushConverter"/>
        <converters:HotspotStatusToTextConverter x:Key="StatusToTextConverter"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Height="48" Background="{StaticResource SurfaceBrush}" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="&#xE701;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Advanced Windows Hotspot" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,4,0">
                    <Button x:Name="MinimizeButton" Style="{StaticResource MaterialIconButton}"
                            Click="MinimizeButton_Click" Width="40" Height="40">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource MaterialIconButton}"
                            Click="CloseButton_Click" Width="40" Height="40">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 主内容区 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,0,8">
                <StackPanel Margin="24,8,24,16">

                    <!-- 状态指示卡片 -->
                    <Border CornerRadius="16" Background="{StaticResource SurfaceContainerLowBrush}" Padding="20,16" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 状态图标 -->
                            <Ellipse x:Name="StatusDot" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,16,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource OutlineBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:HotspotStatus.Running}">
                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:HotspotStatus.Starting}">
                                                <Setter Property="Fill" Value="{StaticResource WarningBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:HotspotStatus.Error}">
                                                <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusText}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource OnSurfaceBrush}"/>
                                <TextBlock x:Name="ErrorText" Text="{Binding ErrorMessage}" FontSize="12"
                                           Foreground="{StaticResource ErrorBrush}" Margin="0,4,0,0"
                                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 网络名称 -->
                    <TextBlock Text="网络名称" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,8"/>
                    <TextBox x:Name="SsidTextBox" Text="{Binding Ssid, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialOutlinedTextBox}"
                             Tag="输入热点名称" MaxLength="32" Margin="0,0,0,20"/>

                    <!-- 密码 -->
                    <TextBlock Text="密码" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource MaterialOutlinedPasswordBox}"
                                     Margin="0,0,-40,0"
                                     Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        <TextBox x:Name="PasswordTextBox" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialOutlinedTextBox}" Tag="输入密码 (8-63位)"
                                 MaxLength="63" Margin="0,0,-40,0"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <Button Grid.Column="1" Style="{StaticResource MaterialIconButton}"
                                Command="{Binding TogglePasswordVisibilityCommand}"
                                Margin="0,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="PasswordToggleIcon" FontFamily="Segoe MDL2 Assets" FontSize="16">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE7B3;"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                <Setter Property="Text" Value="&#xE7B4;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </Grid>
                    <TextBlock Text="密码长度需为8-63个字符" FontSize="11"
                               Foreground="{StaticResource OutlineBrush}" Margin="0,0,0,20"/>

                    <!-- 频段选择 -->
                    <TextBlock Text="频段" FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,8"/>
                    <ComboBox x:Name="BandComboBox"
                              Style="{StaticResource MaterialComboBox}"
                              SelectedIndex="0" Margin="0,0,0,4">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource MaterialComboBoxItem}"/>
                        </ComboBox.ItemContainerStyle>
                        <ComboBoxItem Content="自动" Tag="Auto"/>
                        <ComboBoxItem Content="2.4 GHz" Tag="TwoPointFourGHz"/>
                        <ComboBoxItem Content="5 GHz" Tag="FiveGHz"/>
                    </ComboBox>

                    <!-- 频段选择提示：选择2.4G/5G时自动启用系统热点 -->
                    <Border x:Name="BandAutoHotspotHint" CornerRadius="8" Background="{StaticResource SurfaceContainerHighBrush}"
                            Padding="12,8" Margin="0,4,0,16"
                            Visibility="{Binding IsBandForcingSystemHotspot, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="指定频段需使用系统热点模式（WiFiDirect不支持频段选择）" FontSize="12"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 5GHz不支持提示 -->
                    <Border x:Name="BandWarning" CornerRadius="8" Background="{StaticResource ErrorContainerBrush}"
                            Padding="12,8" Margin="0,4,0,16"
                            Visibility="{Binding ShowBandWarning, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource OnErrorContainerBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="当前无线网卡不支持5GHz频段热点" FontSize="12"
                                       Foreground="{StaticResource OnErrorContainerBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="8" Background="{StaticResource ErrorContainerBrush}"
                            Padding="12,8" Margin="0,4,0,16"
                            Visibility="{Binding Is5GHzSupported, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource OnErrorContainerBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="当前无线网卡不支持5GHz频段热点" FontSize="12"
                                       Foreground="{StaticResource OnErrorContainerBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 允许联网开关 -->
                    <Border CornerRadius="12" Background="{StaticResource SurfaceContainerLowBrush}" Padding="16,8" Margin="0,0,0,8">
                        <CheckBox Style="{StaticResource MaterialSwitch}" IsChecked="{Binding AllowInternet}">
                            <StackPanel>
                                <TextBlock Text="允许通过本机联网" FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource OnSurfaceBrush}"/>
                                <TextBlock Text="关闭后连接热点的设备将无法访问互联网" FontSize="12"
                                           Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </Border>

                    <!-- 网络共享区域（允许联网 + 热点运行中显示） -->
                    <Border CornerRadius="12" Background="{StaticResource SurfaceContainerLowBrush}" Padding="16,12" Margin="0,0,0,8"
                            Visibility="{Binding ShowSharingSection, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="网络共享" FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,4"/>
                            <!-- 适配器选择 -->
                            <TextBlock Text="共享来源（上行网卡）" FontSize="12"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding InternetAdapters}"
                                      SelectedItem="{Binding SelectedInternetAdapter}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource MaterialComboBox}"
                                      ItemContainerStyle="{StaticResource MaterialComboBoxItem}"
                                      Margin="0,0,0,8"
                                      IsEnabled="{Binding IsConfiguringIcs, Converter={StaticResource InverseBoolConverter}}"/>
                            <!-- WiFiDirect模式提示 -->
                            <TextBlock Text="WiFiDirect模式需手动启用网络共享，设备才能访问互联网" FontSize="12"
                                       Foreground="{StaticResource OnSurfaceVariantBrush}" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Visibility="{Binding ShowEnableSharingButton, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <!-- 启用共享按钮（仅WiFiDirect模式显示） -->
                            <Button Command="{Binding EnableSharingCommand}"
                                    HorizontalAlignment="Stretch" Height="36"
                                    Cursor="Hand"
                                    Visibility="{Binding ShowEnableSharingButton, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource OnPrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsConfiguringIcs}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ContentControl>
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="Content" Value="启用网络共享"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConfiguringIcs}" Value="True">
                                                    <Setter Property="Content" Value="正在配置..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </Button>
                            <!-- 结果消息 -->
                            <TextBlock FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding IcsResultMessage}"
                                       Visibility="{Binding HasIcsResult, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IcsResultSuccess}" Value="True">
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IcsResultSuccess}" Value="False">
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 使用系统热点开关 -->
                    <Border CornerRadius="12" Background="{StaticResource SurfaceContainerLowBrush}" Padding="16,8" Margin="0,0,0,24">
                        <StackPanel>
                            <CheckBox Style="{StaticResource MaterialSwitch}" IsChecked="{Binding UseSystemHotspot}">
                                <StackPanel>
                                    <TextBlock Text="使用系统热点" FontSize="14" FontWeight="Medium"
                                               Foreground="{StaticResource OnSurfaceBrush}"/>
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,2,0,0" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="通过Windows移动热点创建，支持频段选择和原生网络共享"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBandForcingSystemHotspot}" Value="True">
                                                        <Setter Property="Text" Value="已由频段选择自动启用（指定频段需使用系统热点）"/>
                                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- 启动/停止按钮 -->
                    <Button x:Name="ActionButton" Command="{Binding ToggleHotspotCommand}" Margin="0,0,0,16">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Height" Value="52"/>
                                <Setter Property="FontSize" Value="16"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Border x:Name="stateLayer" CornerRadius="26" Background="Transparent"/>
                                                <Border x:Name="buttonBorder" CornerRadius="26" Background="{StaticResource PrimaryBrush}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24,0"/>
                                                </Border>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="stateLayer" Property="Background" Value="#1AFFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="stateLayer" Property="Background" Value="#33FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="buttonBorder" Property="Background" Value="#1D1D1D1F"/>
                                                    <Setter Property="Foreground" Value="#611D1D1D"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource OnPrimaryBrush}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>
                                                        <Border x:Name="stateLayer" CornerRadius="26" Background="Transparent"/>
                                                        <Border x:Name="buttonBorder" CornerRadius="26" Background="{StaticResource ErrorBrush}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24,0"/>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="stateLayer" Property="Background" Value="#1AFFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="stateLayer" Property="Background" Value="#33FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ActionIcon" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE704;"/>
                                        <Setter Property="Foreground" Value="{StaticResource OnPrimaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Text" Value="&#xE71A;"/>
                                                <Setter Property="Foreground" Value="{StaticResource OnErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock x:Name="ActionText" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="启动热点"/>
                                        <Setter Property="Foreground" Value="{StaticResource OnPrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Text" Value="停止热点"/>
                                                <Setter Property="Foreground" Value="{StaticResource OnErrorBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:HotspotStatus.Starting}">
                                                <Setter Property="Text" Value="正在启动..."/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static models:HotspotStatus.Stopping}">
                                                <Setter Property="Text" Value="正在停止..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </ScrollViewer>

            <!-- 底部信息栏 -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="0,0,16,16" Padding="20,10">
                <Grid>
                    <TextBlock Text="日志目录: %APPDATA%\AdvancedWindowsHotspot\logs" FontSize="11"
                               Foreground="{StaticResource OutlineBrush}" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Right" FontSize="11" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource OutlineBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Is5GHzSupported}" Value="True">
                                        <Setter Property="Text" Value="2.4GHz / 5GHz"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Is5GHzSupported}" Value="False">
                                        <Setter Property="Text" Value="仅 2.4GHz"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
